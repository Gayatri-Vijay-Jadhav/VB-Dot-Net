Module Arithematic

    Sub Main()

        Dim A As Integer = 20
        Dim B As Integer = 10
        Dim C As Double

        C = A + B
        Console.WriteLine("Addition: " & C)

        C = A - B
        Console.WriteLine("Subtraction: " & C)

        C = A * B
        Console.WriteLine("Multiplication: " & C)

        C = A / B
        Console.WriteLine("Division: " & C)

        C = A Mod B
        Console.WriteLine("Modulus: " & C)

        C = A ^ B
        Console.WriteLine("Power: " & C)

        Console.ReadLine()

    End Sub

End Module
